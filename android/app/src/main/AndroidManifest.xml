<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage permission for older Android (API < 33) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Required by file_picker on some devices -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="FormulaDoc"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════════════════════════════
             REQUIRED: declares this app uses Flutter's Android v2 embedding.
             Its absence is exactly what produces:
               "Build failed due to use of deleted Android v1 embedding."
             ══════════════════════════════════════════════════════════════ -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Flutter normal launch -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Static app shortcuts (long-press launcher icon) -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

            <!-- ══════════════════════════════════════════════════════════════
                 "Open with FormulaDoc" — DOCX MIME type (content:// URIs)
                 Works with: Google Drive, Gmail attachments, Downloads app,
                             modern file managers
                 ══════════════════════════════════════════════════════════════ -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
            </intent-filter>

            <!-- PDF — content:// URIs (Google Drive, Gmail, Downloads) -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/pdf" />
            </intent-filter>

            <!-- XLSX — content:// URIs -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
            </intent-filter>

            <!-- "Open with" via file URI (some older file managers) -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:mimeType="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
            </intent-filter>

            <!-- PDF via file URI -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" />
                <data android:mimeType="application/pdf" />
            </intent-filter>

            <!-- "Open with" by file extension — file managers that send */* MIME -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.docx" />
            </intent-filter>

            <!-- PDF by extension -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.pdf" />
            </intent-filter>

            <!-- XLSX by extension -->
            <intent-filter android:label="@string/open_with_formuladoc">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.xlsx" />
            </intent-filter>

            <!-- Flutter embedding meta-data -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
        </activity>

        <!-- FileProvider for receive_sharing_intent temp file sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
